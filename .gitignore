# Create .gitignore
touch .gitignore

# Add common Python ignores
cat << EOF > .gitignore
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environments
.env
.venv
env/
venv/
ENV/

# IDE specific files
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Project specific
*.log
*.sqlite3
/data/
/models/
.pytest_cache/
.coverage
htmlcov/

# ML specific
*.h5
*.pth
*.onnx
tensorboard/
EOF